# Copy this file to .env.local for local development.
# Never commit .env.local — it is already in .gitignore.

# -------------------------------------------------------
# REQUIRED — Canonical site URL
# Used in: metadata, OG tags, sitemap.xml, JSON-LD, canonicals
# Set to your production domain once the DNS cutover is done.
# -------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://uat.hotshoes.com.my

# -------------------------------------------------------
# REQUIRED — Contact form (Resend)
# Get your API key from resend.com → API Keys
# -------------------------------------------------------
RESEND_API_KEY=re_...
