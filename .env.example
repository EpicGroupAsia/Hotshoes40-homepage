# Copy this file to .env.local for local development.
# Never commit .env.local — it is already in .gitignore.

# -------------------------------------------------------
# REQUIRED — Canonical site URL
# Used in: metadata, OG tags, sitemap.xml, JSON-LD, canonicals
# Set to your production domain once the DNS cutover is done.
# -------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://uat.hotshoes.com.my

# -------------------------------------------------------
# REQUIRED — Contact form (Gmail SMTP)
# SMTP_USER: the Gmail / Google Workspace address used to send
# SMTP_PASS: App Password from myaccount.google.com (NOT your login password)
#   How to get an App Password:
#   1. myaccount.google.com → Security → 2-Step Verification (enable if not on)
#   2. Security → App passwords → name it "Hotshoes Contact Form" → Generate
#   3. Copy the 16-character password (no spaces) and paste below
# -------------------------------------------------------
SMTP_USER=your-email@hotshoes.asia
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
